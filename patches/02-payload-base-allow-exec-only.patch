From 9b72f6a2ef3c2da68916984f6b2d4ded99f0348e Mon Sep 17 00:00:00 2001
From: at-xx-frida <noreply@local>
Date: Fri, 22 May 2026 00:00:00 +0800
Subject: [PATCH] relax payload-base library check to executable-only

On Android 10+ many system .so files (notably /system/lib64/libstagefright.so)
are mapped as PROT_EXEC only (--xp) with a separate PROT_READ segment (r--p),
not the legacy r-xp. Upstream now anchors the payload base on any executable
libstagefright.so / libmedia.so mapping (the readable requirement was dropped),
which already resolves "Unable to pick a payload base".

This refines only the protection bookkeeping: synthesize
payload_original_protection from the mapping's actual flags instead of
hardcoding PROT_READ | PROT_EXEC, so an exec-only (--xp) anchor page is
restored to exec-only after the agent detaches rather than gaining a spurious
READ bit.
---
 src/linux/linux-host-session.vala | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/linux/linux-host-session.vala b/src/linux/linux-host-session.vala
index 44bd940..6eb5284 100644
--- a/src/linux/linux-host-session.vala
+++ b/src/linux/linux-host-session.vala
@@ -1712,7 +1712,9 @@ namespace Frida {
 				if (payload_base == 0 && m.executable &&
 						(path.has_suffix ("/libstagefright.so") || path.has_suffix ("/libmedia.so"))) {
 					payload_base = m.end - Gum.query_page_size ();
-					payload_original_protection = Posix.PROT_READ | Posix.PROT_EXEC;
+					payload_original_protection = Posix.PROT_EXEC;
+					if (m.readable)
+						payload_original_protection |= Posix.PROT_READ;
 					if (m.writable)
 						payload_original_protection |= Posix.PROT_WRITE;
 					payload_path = path;
